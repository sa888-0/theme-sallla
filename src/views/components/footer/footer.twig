<footer class="lux-footer store-footer">
  <div class="lux-footer__inner">
    <div class="container">
      <div class="lux-footer__grid">

        {# Brand column #}
        <div class="lux-footer__brand">
          <a href="{{ link('/') }}" class="lux-footer__logo">
            <img src="{{ store.logo|cdn(175) }}" alt="{{ store.name }}" class="lux-footer__logo-img invert">
          </a>
          {% if store.description %}
            <p class="lux-footer__desc">{{ store.description|raw }}</p>
          {% endif %}
          <salla-social class="lux-footer__social"></salla-social>
        </div>

        {# Quick links column #}
        <div class="lux-footer__col">
          <h4 class="lux-footer__col-title">{{ trans('blocks.footer.pages_links') }}</h4>
          <salla-menu source="footer" with-cookie-preferences class="lux-footer__menu"></salla-menu>
        </div>

        {# Contact column #}
        <div class="lux-footer__col">
          <h4 class="lux-footer__col-title">{{ trans('blocks.footer.contact_us') }}</h4>
          <salla-contacts class="lux-footer__contacts"></salla-contacts>
        </div>

        {# App + trust column #}
        <div class="lux-footer__col">
          <salla-apps-icons class="lux-footer__apps"></salla-apps-icons>
          <div class="lux-footer__trust">
            <salla-trust-badges dark></salla-trust-badges>
            {% if store.settings.tax.number %}
              <div class="lux-footer__vat">
                {% if store.settings.tax.certificate %}
                  <a class="load-img-onclick" data-modal-id="modal-value-tax" href="#/">
                    <img width="40" height="50" src="{{ 'images/tax.png'|cdn(70,70) }}" loading="lazy" class="w-10 rounded-sm opacity-60 hover:opacity-100 transition-opacity" alt="vat">
                  </a>
                {% endif %}
                <div>
                  <p class="lux-footer__vat-label">{{ trans('common.elements.tax_number') }}</p>
                  <b class="lux-footer__vat-number">{{ store.settings.tax.number }}</b>
                </div>
              </div>
              {% if store.settings.tax.certificate %}
                <salla-modal sub-title-first sub-title="{{ trans('common.elements.tax_number') }}" modal-title="{{ store.settings.tax.number }}" id="modal-value-tax">
                  <div class="flex justify-center max-w-full">
                    <img class="w-full" loading="lazy" data-src="{{ store.settings.tax.certificate }}" alt="{{ store.settings.tax.number }}"/>
                  </div>
                </salla-modal>
              {% endif %}
            {% endif %}
          </div>
        </div>

      </div>
    </div>
  </div>

  {# Bottom bar #}
  <div class="lux-footer__bottom">
    <div class="container lux-footer__bottom-inner">
      <span class="lux-footer__copy">{% hook copyright %}</span>
      <salla-payments class="lux-footer__payments"></salla-payments>
    </div>
  </div>

  <span class="hidden bottom-2 rtl:pl-24 ltr:pr-24 md:grid-cols-3 opacity-40"></span>
</footer>
