{#
| Variable         | Type    | Description                     |
|------------------|---------|---------------------------------|
| cart             | object  |                                 |
| cart.items_count | int     |                                 |
| cart.total       | string  | Formatted total ex: "١٠٠ ر.س"   |
#}
<header class="store-header lux-header">
  <div id="mainnav" class="lux-nav">
    <div class="container lux-nav__inner">

      {# RIGHT side (RTL: visually on the right) — Hamburger + Search #}
      <div class="lux-nav__side">
        <a class="lux-hamburger mburger mburger--collapse lg:hidden" href="#mobile-menu" aria-label="فتح القائمة">
          <i class="sicon-menu text-2xl"></i>
        </a>
        <div class="hidden lg:block lux-search-wrap">
          <salla-search inline oval height="36"></salla-search>
        </div>
        {% if store.settings.is_multilingual or store.settings.currencies_enabled %}
          <salla-localization-modal show-trigger class="hidden lg:flex"></salla-localization-modal>
        {% endif %}
        {% if store.scope %}
          <button class="lux-scope-btn hidden lg:flex" onclick="salla.event.dispatch('scopes::open', {'mode': 'default'})">
            <i class="sicon-location ltr:mr-1 rtl:ml-1 text-sm"></i>{{ store.scope.name }}
          </button>
        {% endif %}
      </div>

      {# CENTER — Logo (absolute) #}
      <div class="lux-nav__logo">
        <a href="{{ store.url }}" class="lux-logo-link">
          <img fetchpriority="high" loading="eager" width="175" height="40"
               src="{{ store.logo|cdn(175) }}" alt=""
               onerror="this.style.display='none';this.nextElementSibling.style.display='flex'">
          <span class="lux-logo-text" style="display:none">{{ store.name }}</span>
          {% if is_page('index') %}
            <h1 style="position:absolute;width:1px;height:1px;padding:0;margin:-1px;overflow:hidden;clip:rect(0,0,0,0);white-space:nowrap;border:0">{{ store.name }}</h1>
          {% else %}
            <h2 style="position:absolute;width:1px;height:1px;padding:0;margin:-1px;overflow:hidden;clip:rect(0,0,0,0);white-space:nowrap;border:0">{{ store.name }}</h2>
          {% endif %}
        </a>
      </div>

      {# LEFT side (RTL: visually on the left) — User + Cart #}
      <div class="lux-nav__side lux-nav__side--left">
        <button class="lux-icon-btn lg:hidden" onclick="salla.event.dispatch('search::open')">
          <i class="sicon-search text-xl"></i>
        </button>
        <salla-user-menu avatar-only show-header show-trigger></salla-user-menu>
        <salla-cart-summary>
          <i slot="icon" class="sicon-shopping-bag lux-cart-icon"></i>
        </salla-cart-summary>
      </div>

    </div>
  </div>

  {# Desktop category nav — shown below main nav #}
  <nav class="lux-cat-nav hidden lg:block">
    <div class="container lux-cat-nav__inner">
      <custom-main-menu></custom-main-menu>
    </div>
  </nav>
</header>
