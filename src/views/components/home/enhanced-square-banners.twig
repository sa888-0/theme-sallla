{#
| Variable                        | Type     | Description                                                                  |
|---------------------------------|----------|------------------------------------------------------------------------------|
| component                       | object   | Contains merchant settings for fields from twilight.json `component` section |
| component.banners               | object[] | list of banners                                                              |
| component.banners[].image       | string   |                                                                              |
| component.banners[].url         | string   |                                                                              |
| component.banners[].title       | ?string  |                                                                              |
| component.banners[].description | ?string  |                                                                              |
| position                        | int      | Sorting number start from zero                                               |
#}
<section class="lux-categories s-block s-block--full-bg">
  <div class="container lux-categories__inner">
    {% set cols = component.banners|length <= 2 ? component.banners|length : 3 %}
    <div class="lux-categories__grid lux-categories__grid--{{ cols }}">
      {% for banner in component.banners %}
        <a href="{{ banner.url }}" class="lux-cat-card lux-tilt lux-reveal lux-reveal--d{{ loop.index }} group">
          <div class="lux-cat-card__img-wrap">
            <img
              src="{{ banner.image }}"
              alt="{{ banner.title }}"
              loading="lazy"
              class="lux-cat-card__img">
          </div>
          <div class="lux-cat-card__overlay">
            {% if banner.title %}
              <h3 class="lux-cat-card__title">{{ banner.title }}</h3>
              <div class="lux-cat-card__line"></div>
              <span class="lux-cat-card__cta">SHOP COLLECTION</span>
            {% endif %}
            {% if banner.description %}
              <p class="lux-cat-card__desc">{{ banner.description }}</p>
            {% endif %}
          </div>
        </a>
      {% endfor %}
    </div>
  </div>
</section>
